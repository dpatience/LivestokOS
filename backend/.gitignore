# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
livestok_os-*.tar

# Dialyzer PLT files
/priv/plts/
*.plt
*.plt.hash

# ElixirLS / IDE build artifacts
.elixir_ls/
.elixir-tools/

# Environment variables — never commit secrets
.env
.env.*
!.env.example

# OS and editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/

# Local editor settings (keep shared launch configs out of git)
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# AI-generated runtime outputs (keep directory structure via .gitkeep)
apps/livestok_os_ai/priv/ai_research/*
!apps/livestok_os_ai/priv/ai_research/.gitkeep
apps/livestok_os_ai/priv/ai_proposals/*
!apps/livestok_os_ai/priv/ai_proposals/.gitkeep
apps/livestok_os_ai/priv/prompts/vet_consult_system_proposed_*.txt

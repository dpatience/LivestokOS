# =============================================================================
# LivestokOS — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# Every cow and farm record in the system is scoped by farm_id — credentials
# here must remain farm-specific where noted.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

# TCP port the Phoenix endpoint listens on (default: 4000)
PORT=4000

# Set to "true" when starting the app from a compiled release (mix release).
# Leave unset (or false) when running via `mix phx.server`.
PHX_SERVER=false

# Public hostname for the production deployment (used in URLs, HSTS, etc.)
PHX_HOST=example.com

# Enable DNS-based cluster node discovery in production multi-node deployments.
# Leave blank for single-node / dev.
DNS_CLUSTER_QUERY=


# -----------------------------------------------------------------------------
# DATABASE  (PostgreSQL + PostGIS)
# -----------------------------------------------------------------------------
# Used in production (runtime.exs). Dev credentials live in config/dev.exs.

# Full Ecto/PostgreSQL connection URL.
# Format: ecto://USER:PASSWORD@HOST/DATABASE
DATABASE_URL=ecto://livestok_user:CHANGE_ME@localhost/livestok_os_prod

# Connection pool size per node (default: 10)
POOL_SIZE=10

# Set to "true" or "1" to bind the DB socket over IPv6.
ECTO_IPV6=false


# -----------------------------------------------------------------------------
# PHOENIX SECURITY KEYS
# -----------------------------------------------------------------------------

# Phoenix session / cookie signing key.
# Generate with: mix phx.gen.secret
# Required in production; a default is used in dev/test.
SECRET_KEY_BASE=CHANGE_ME_run_mix_phx.gen.secret

# Guardian JWT signing secret.
# Generate with: mix guardian.gen.secret  (or any 64+ char random string)
# Required in production.
GUARDIAN_SECRET_KEY=CHANGE_ME_generate_with_mix_guardian.gen.secret

# HMAC signing secret for Digital Passport / supply-chain QR codes.
# Must match any verifier (e.g. abattoir scanning system).
QR_SECRET=CHANGE_ME_64_char_random_string

# Per-farm Ed25519 private key for Digital Passport signing.
# TODO: generate per-farm keypair at onboarding and store securely (e.g. Vault).
# Until implemented, passports are unsigned (signature: nil).
FARM_PASSPORT_SIGNING_KEY=


# -----------------------------------------------------------------------------
# FRONTEND / CORS
# -----------------------------------------------------------------------------

# Allowed CORS origin for the frontend app.
# In development: http://localhost:5173
FRONTEND_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# MAPPING  (Mapbox)
# -----------------------------------------------------------------------------
# Used by the frontend for farm boundary drawing, paddock creation, and
# geofence visualization. Each farm draws its own area and paddocks on the map
# so LivestokOS knows farm boundaries for NDVI requests and geofence checks.
# Prefix with VITE_ to expose to the Vite/React frontend bundle.

# Mapbox public token — get from https://account.mapbox.com/
VITE_MAPBOX_TOKEN=pk.CHANGE_ME


# -----------------------------------------------------------------------------
# SATELLITE / NDVI  (Copernicus Sentinel Hub)
# -----------------------------------------------------------------------------
# Used by livestok_os_ai and livestok_os_satellite to fetch Sentinel-2 NDVI
# imagery per paddock (pasture/mixed farms only).
# API docs: https://documentation.dataspace.copernicus.eu/APIs/SentinelHub.html
#
# If unset or empty, the system falls back to deterministic NDVI simulation —
# safe for development and CI, but not for production carbon calculations.

# OAuth2 client credentials for Copernicus Data Space
# Register at: https://dataspace.copernicus.eu/
SATELLITE_CLIENT_ID=CHANGE_ME
SATELLITE_CLIENT_SECRET=CHANGE_ME

# Legacy Bearer-token API key (retained for backward compat with current code).
# Will be superseded by OAuth2 client credentials above.
SATELLITE_API_KEY=CHANGE_ME


# -----------------------------------------------------------------------------
# WEATHER  (Open-Meteo)
# -----------------------------------------------------------------------------
# Used by livestok_os_satellite WeatherJob for grass-recovery projections.
# Open-Meteo is free and requires no API key for standard forecast endpoints.
# API docs: https://open-meteo.com/en/docs
# No credential needed — leave these as reference only.
#
# OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast  # default in code


# -----------------------------------------------------------------------------
# GENERATIVE AI / LLM
# -----------------------------------------------------------------------------
# Used by livestok_os_ai for the RAG pipeline, embeddings, and any LLM-assisted
# coaching recommendations (Stage 6 AI Grazing Coach).
#
# Configure at most ONE provider. The AI app reads whichever key is present.

# OpenAI (GPT-4o, embeddings via text-embedding-3-small, etc.)
# Docs: https://platform.openai.com/docs/api-reference
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Alternatively, any OpenAI-compatible endpoint (Ollama, local LLM, etc.)
# LLM_API_KEY=CHANGE_ME
# LLM_API_BASE_URL=http://localhost:11434/v1


# -----------------------------------------------------------------------------
# EMAIL  (Swoosh — production adapter)
# -----------------------------------------------------------------------------
# In development, Swoosh uses a local in-memory adapter (no credentials needed).
# Choose ONE production adapter below and uncomment it.

# --- Mailgun ---
# MAILGUN_API_KEY=CHANGE_ME
# MAILGUN_DOMAIN=mg.yourdomain.com

# --- SendGrid ---
# SENDGRID_API_KEY=CHANGE_ME

# --- SMTP fallback ---
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_USERNAME=CHANGE_ME
# SMTP_PASSWORD=CHANGE_ME


# -----------------------------------------------------------------------------
# FEED ROBOT INTEGRATION  (zero_grazing / mixed farms)
# -----------------------------------------------------------------------------
# LivestokOS triggers targeted inhibitor doses through the feed robot when a
# cow is flagged as a high methane emitter. The integration point is currently
# stubbed (LivestokOs.FeedRobot.StubAdapter).
# TODO: Replace stub with vendor-specific adapter when API contract is known.

FEED_ROBOT_API_URL=https://feedrobot.vendor.example/api/v1
FEED_ROBOT_API_KEY=CHANGE_ME


# -----------------------------------------------------------------------------
# LORAWAN GATEWAY
# -----------------------------------------------------------------------------
# Credentials / network-server config for the LoRaWAN uplink.
# The current implementation is uplink-only (no downlink supported yet).
# Collar deterrent commands use a polling endpoint as fallback.

LORAWAN_NETWORK_SERVER_URL=https://your-lns.example/api
LORAWAN_APP_KEY=CHANGE_ME


# -----------------------------------------------------------------------------
# AGRONOMIC / EMISSION FACTORS
# -----------------------------------------------------------------------------
# These are science-derived constants, not secrets, but they MUST be sourced
# from verified references rather than hardcoded placeholders.
# They are listed here so operators know which values need agronomic sign-off.
#
# TODO: Replace each placeholder with a verified, cited value before production.

# IPCC Tier 2 methane emission factor for enteric fermentation
# (kg CH4 per head per day — varies by breed, diet, region).
# Reference: IPCC 2006 GL, Volume 4, Chapter 10, Table 10.2
# IPCC_METHANE_EMISSION_FACTOR=PLACEHOLDER_needs_verification

# Methane yield factor for slurry biogas mass-balance calculation
# (m³ CH4 per m³ slurry — depends on herd's TMR composition).
# BIOGAS_METHANE_YIELD_FACTOR=PLACEHOLDER_needs_verification

# Default NDVI threshold below which a lick-block alert is triggered.
# Set per-farm via the dashboard; this env var provides the system-wide default.
# Agronomic validation required before enabling in production.
# NDVI_LICK_BLOCK_ALERT_THRESHOLD=0.3

# Default estrus proxy score threshold for heat-cycle alert.
# Validated by agronomist before production use.
# ESTRUS_PROXY_THRESHOLD=0.7


# -----------------------------------------------------------------------------
# SSL  (optional, production HTTPS termination at app level)
# -----------------------------------------------------------------------------
# Only needed if TLS is terminated by the Phoenix app directly rather than
# a load balancer / reverse proxy.

# SSL_KEY_PATH=/etc/ssl/private/livestok_os.key
# SSL_CERT_PATH=/etc/ssl/certs/livestok_os.crt
